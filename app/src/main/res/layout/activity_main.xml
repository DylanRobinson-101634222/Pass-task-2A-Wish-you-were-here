<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.PassTask2AWishYouWereHere">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorPrimary"
            app:title="@string/app_name" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                style="@style/ScreenHeadingStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_heading" />

            <Spinner
                android:id="@+id/spinner_region"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp" />

            <CheckBox
                android:id="@+id/checkbox_recent_only"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/recent_only_checkbox" />

            <RadioGroup
                android:id="@+id/rg_sort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rb_sort_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/sort_name" />

                <RadioButton
                    android:id="@+id/rb_sort_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/sort_rating" />
            </RadioGroup>

            <GridLayout
                android:id="@+id/location_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="2">

                <include
                    android:id="@+id/card_1"
                    layout="@layout/location_card"
                    android:layout_width="0dp"
                    android:layout_height="240dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp" />

                <include
                    android:id="@+id/card_2"
                    layout="@layout/location_card"
                    android:layout_width="0dp"
                    android:layout_height="240dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp" />

                <include
                    android:id="@+id/card_3"
                    layout="@layout/location_card"
                    android:layout_width="0dp"
                    android:layout_height="240dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp" />

                <include
                    android:id="@+id/card_4"
                    layout="@layout/location_card"
                    android:layout_width="0dp"
                    android:layout_height="240dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp" />

            </GridLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

