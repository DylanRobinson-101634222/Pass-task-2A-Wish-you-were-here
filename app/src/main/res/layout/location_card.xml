<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="8dp"
    android:background="@drawable/bg_location_card"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Image takes up all available space above the fixed bottom section -->
    <ImageView
        android:id="@+id/iv_location"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:contentDescription="@string/location_image_content_description"
        android:scaleType="centerCrop" />

    <!-- Title sits just below the image -->
    <TextView
        android:id="@+id/tv_location_title"
        style="@style/LocationTitleStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/placeholder_location" />

    <!-- Rating and last visit are always pinned here at the bottom -->
    <RatingBar
        android:id="@+id/rb_location_rating"
        style="?android:attr/ratingBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="6dp"
        android:isIndicator="true"
        android:numStars="5"
        android:stepSize="0.5" />

    <TextView
        android:id="@+id/tv_last_visit"
        style="@style/LocationMetaStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="@string/placeholder_date" />

</LinearLayout>

